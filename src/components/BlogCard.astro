---
import FormattedDate from './FormattedDate.astro';

interface Props {
	slug: string;
	title: string;
	description: string;
	pubDate: Date;
	tags: string[];
}

const { slug, title, description, pubDate, tags } = Astro.props;
---

<article
	class="post-card"
	data-post
	data-href={`/blog/${slug}/`}
	data-title={title}
	data-description={description}
	data-tags={tags.join(' ').toLowerCase()}
	role="link"
	tabindex="0"
>
	<h3>{title}</h3>
	<p class="meta">
		<span class="date"><FormattedDate date={pubDate} /></span>
		<span class="tags">
			{
				tags.map((tag) => (
					<button type="button" class="tag" data-tag-filter={tag.toLowerCase()}>
						#{tag}
					</button>
				))
			}
		</span>
	</p>
	<p class="description">{description}</p>
</article>

<style>
	.post-card {
		border: 1px solid var(--border);
		background: var(--surface);
		padding: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.7rem;
		cursor: pointer;
		transition: box-shadow 0.2s ease, transform 0.2s ease;
	}
	.post-card:hover {
		box-shadow: 0 0 0 1px var(--accent); /*, 0 0 22px rgba(236, 186, 130, 0.45);*/
		transform: translateY(-1px);
	}
	.post-card h3 {
		margin: 0;
		font-size: 1.1rem;
		color: var(--text);
	}
	.meta {
		display: flex;
		gap: 0.75rem;
		align-items: baseline;
		justify-content: space-between;
		margin: 0;
		font-size: 0.85rem;
		color: var(--secondary-text);
	}
	.tags {
		display: flex;
		gap: 0.35rem;
		flex-wrap: wrap;
		justify-content: flex-end;
	}
	.tag {
		font: inherit;
		font-size: 0.8rem;
		color: var(--accent);
		background: transparent;
		border: 1px solid var(--border);
		padding: 0.15rem 0.45rem;
		cursor: pointer;
	}
	.description {
		margin: 0;
		color: var(--secondary-text);
		font-size: 0.95rem;
		overflow: hidden;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		line-clamp: 2;
		-webkit-box-orient: vertical;
	}
</style>
